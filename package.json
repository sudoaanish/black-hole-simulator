  "version": "1.0.0",
  "description": "Real-time Schwarzschild black hole simulator - Geodesica. Physically accurate gravitational lensing, accretion disk, Doppler shift and photon ring running entirely in the browser via WebGL2.",
  "author": "sudoaanish",
  "license": "MIT",
  "repository": "https://github.com/sudoaanish/black-hole-simulator",
  "homepage": "https://github.com/sudoaanish/black-hole-simulator",
  "bugs": "https://github.com/sudoaanish/black-hole-simulator/issues",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tsc": "tsc",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "webgl2",
    "glsl",
    "typescript",
    "physics",
    "black-hole",
    "gravitational-lensing"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
